RHYTHMIQ_ADDR=:8080
RHYTHMIQ_BASE_URL=http://127.0.0.1:8080
RHYTHMIQ_ALLOWED_ORIGINS=
RHYTHMIQ_DB_DRIVER=postgres
RHYTHMIQ_DB_PATH=./rhythmiq.db
RHYTHMIQ_DB_DSN=postgres://rhythmiq:rhythmiq@127.0.0.1:5432/rhythmiq?sslmode=disable
# Use at least 32 random characters in production.
# This value signs sessions and encrypts stored Spotify tokens.
RHYTHMIQ_SESSION_SECRET=change-me-in-production

SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URL=http://127.0.0.1:8080/api/auth/callback

# Optional AI recommendations
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
